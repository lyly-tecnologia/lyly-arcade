# Copia este archivo como .env.local y rellena tus valores reales

# URL de tu proyecto Supabase (ej: https://xyzxyzxyz.supabase.co)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon/public de Supabase (encontrada en Project Settings > API)
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# URL de tu Lambda Function URL de AWS
VITE_API_URL=https://TU_LAMBDA_URL.lambda-url.us-east-1.on.aws
